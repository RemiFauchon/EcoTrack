# ─── Base de données (PostgreSQL + PostGIS) ───
POSTGRES_USER=ecotrack
POSTGRES_PASSWORD=ecotrack
POSTGRES_DB=ecotrack
DATABASE_HOST=postgres
DATABASE_PORT=5432

# ─── Redis (cache, sessions, classements gamification) ───
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Broker MQTT (ingestion IoT) ───
MQTT_URL=mqtt://mosquitto:1883
MQTT_TOPIC=ecotrack/measurements

# ─── API ───
API_PORT=3000
NODE_ENV=development

# ─── Authentification JWT ───
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=900          # 15 min (en secondes)
JWT_REFRESH_TTL=604800      # 7 jours (en secondes)

# ─── Simulateur IoT ───
SIMULATOR_ENABLED=true
SIMULATOR_CONTAINERS=200     # nb de conteneurs simulés en local (2000 en cible)
SIMULATOR_INTERVAL_MS=15000  # cadence locale (15 min réel)

# ─── Frontend ───
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000
