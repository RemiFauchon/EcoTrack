# ─── Production (VPS) ─── Copier en .env.prod et renseigner les secrets.
# Lancement : docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# ── Reverse proxy ──
# Mode INTÉGRATION (un proxy existe déjà sur le VPS — c'est ton cas) :
#   DOMAIN=:80     -> notre Caddy sert en HTTP en interne, le proxy existant gère le HTTPS
#   WEB_PORT=8088  -> port localhost exposé, à cibler depuis le proxy existant
# Mode AUTONOME (rien sur 80/443) :
#   DOMAIN=ecotrack.mondomaine.fr (HTTPS auto par Caddy) + ports 80/443 dans le compose
DOMAIN=:80
WEB_PORT=8088

# Base de données (PostgreSQL + PostGIS)
POSTGRES_USER=ecotrack
POSTGRES_PASSWORD=CHANGE_ME_mot_de_passe_fort
POSTGRES_DB=ecotrack
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Schéma : true pour la démo (création auto des tables) ; passer à false avec des migrations
DB_SYNCHRONIZE=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MQTT (broker interne)
MQTT_URL=mqtt://mosquitto:1883
MQTT_TOPIC=ecotrack/measurements

# API
API_PORT=3000
NODE_ENV=production

# JWT — GÉNÉRER des secrets uniques : openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Simulateur IoT (alimente la démo)
SIMULATOR_ENABLED=true
SIMULATOR_CONTAINERS=200
SIMULATOR_INTERVAL_MS=15000
